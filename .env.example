# ==============================================================================
# SkyleBank Environment Variables Template (.env.example)
# Copy this file to .env and fill in the values for local development.
# Do NOT commit the .env file to version control.
# ==============================================================================

# System Environment
SPRING_PROFILES_ACTIVE=dev

# Backend Server Configuration
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database Configurations (PostgreSQL)
# For local dev: jdbc:postgresql://localhost:5432/skylebank_db
# For production: jdbc:postgresql://<supabase-host>:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/skylebank_db
DB_USERNAME=skylebank_user
DB_PASSWORD=skylebank_secure_password

# Caching Configurations (Redis - Optional for Prod)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security & Cryptography
# Generate a secure 256-bit key: openssl rand -base64 32
JWT_SECRET=dGhpcy1pcy1hLXNlY3VyZS1hbmQtc3Ryb25nLWp3dC1zZWNyZXQta2V5LTMyLWJ5dGVz
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
# For local development: Lax. For production cross-domain: None.
JWT_COOKIE_SAME_SITE=Lax

# Email API Settings (Gmail SMTP or Resend SMTP)
# For local dev: Host=localhost, Port=1025 (MailHog)
# For Gmail Prod: Host=smtp.gmail.com, Port=587, Username=your-email@gmail.com, Password=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ayodejiakinsunmade05@gmail.com
SMTP_PASSWORD=

# Initial Setup & Administration
INITIAL_ADMIN_EMAIL=admin@skylebank.com
INITIAL_ADMIN_PASSWORD=AdminSecurePassword123!
