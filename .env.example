# ==============================================================================
# SkyleBank Environment Variables Template (.env.example)
# Copy this file to .env and fill in the values for local development.
# Do NOT commit the .env file to version control.
# ==============================================================================

# System Environment
SPRING_PROFILES_ACTIVE=dev

# Backend Server Configuration
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database Configurations (PostgreSQL)
# For local dev: jdbc:postgresql://localhost:5432/skylebank_db
# For production: jdbc:postgresql://<supabase-host>:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/skylebank_db
DB_USERNAME=skylebank_user
DB_PASSWORD=skylebank_secure_password

# Caching Configurations (Redis - Optional for Prod)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security & Cryptography
# Generate a secure 256-bit key: openssl rand -base64 32
JWT_SECRET=dGhpcy1pcy1hLXNlY3VyZS1hbmQtc3Ryb25nLWp3dC1zZWNyZXQta2V5LTMyLWJ5dGVz
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Email API Settings (Resend SMTP)
# For production, set actual SMTP settings from Resend
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
RESEND_API_KEY=re_1234567890abcdef

# Initial Setup & Administration
INITIAL_ADMIN_EMAIL=admin@skylebank.com
INITIAL_ADMIN_PASSWORD=AdminSecurePassword123!
